# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=small

# cpu | cuda — set to cuda ONLY on a GPU host also run with
# docker-compose.gpu.yml (see MANUAL.html "Setup & deployment")
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Self-hosted vLLM OpenAI-compatible endpoint (question bank generation)
# Base URL only — do NOT include /chat/completions, the client SDK appends it.
VLLM_API_BASE=http://<vllm-host>:<port>/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen/Qwen3-30B-A3B

# Host-side port the app is exposed on (change if 8000 is already taken)
WEB_PORT=8000
